\begin_layout Section
Rules for equation typesetting
\end_layout

\begin_layout Standard
\begin_inset CommandInset label
LatexCommand label
name "eq:equationtypesetting"

\end_inset

There are rules for typesetting equations:
\end_layout

\begin_layout Itemize
Variables are set in italics:
 
\begin_inset Formula $u$
\end_inset


\end_layout

\begin_layout Itemize
Subscripts,
 constants,
 physical units,
 and function names are set upright(roman):
 
\begin_inset Formula $\mathrm{kA}$
\end_inset


\end_layout

\begin_layout Itemize
A small space is inserted between a numerical value and the unit:
 
\begin_inset Formula $U=5\,\mathrm{V}$
\end_inset


\end_layout

\begin_layout Itemize
Constant subscripts are set in italics:
 
\begin_inset Formula $u_{\mathrm{min}}$
\end_inset


\end_layout

\begin_layout Itemize
Variable:
 
\begin_inset Formula $\overline{u}=\frac{1}{42}\sum_{k=1}^{42}u_{k}$
\end_inset


\end_layout

\begin_layout Itemize
A multiplication dot is used for multiplication:
 
\begin_inset Formula $x\cdot y=z$
\end_inset


\end_layout

\begin_layout Itemize
A cross is used for the cross product:
 
\begin_inset Formula $\boldsymbol{x}\times\boldsymbol{y}=\boldsymbol{z}$
\end_inset

.
 Furthermore,
 it may be used to specify areas:
 
\begin_inset Formula $A=25\,\mathrm{m}\times14\,\mathrm{m}$
\end_inset

.
 The cross 
\begin_inset Formula $\times$
\end_inset

 is not the same character as the third-to-last letter of the alphabet:
 x.
\end_layout

\begin_layout Itemize
An asterisk is used for convolution:
 
\begin_inset Formula $a*b$
\end_inset


\end_layout

\begin_layout Itemize
For inline equations,
 
\begin_inset Formula $\mathrm{e}^{\mathrm{j}\,\varphi}$
\end_inset

 can be written instead of:
 
\begin_inset Formula $\mathrm{exp}\left(\mathrm{j}\,\varphi\right)$
\end_inset


\end_layout

\begin_layout Itemize
For inline equations,
 a slash can be used instead of a fraction (
\begin_inset Formula $\frac{7}{8}$
\end_inset

) :
 
\begin_inset Formula $7/8$
\end_inset

.
\end_layout

\begin_layout Standard
thus:
 
\begin_inset Formula $x_{\mathrm{start}}$
\end_inset

 instead of 
\begin_inset Formula $x_{start}$
\end_inset

,
 
\begin_inset Formula $\mathrm{sin}(x)$
\end_inset

 instead of 
\begin_inset Formula $sin(x)$
\end_inset

,
 
\begin_inset Formula $z=4+\mathrm{j}\,6$
\end_inset

 instead of 
\begin_inset Formula $z=4+j\,6$
\end_inset

,
 
\begin_inset Formula $i=4{,}5\,\mathrm{A}$
\end_inset

 instead of 
\begin_inset Formula $i=4{,}5\,A$
\end_inset

 and 
\begin_inset Formula $\mathrm{e}^{\mathrm{j}\,\pi}$
\end_inset

 instead of 
\begin_inset Formula $e^{j\,\pi}$
\end_inset

.
 For numerical values in equations,
 the comma acting as a decimal separator should be enclosed in curly braces.
 This prevents incorrect spacing.
 Correct:
 
\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
lstinline[language=TeX]|$
\backslash
pi=3{,}14$|
\end_layout

\end_inset

 yields:
 
\begin_inset Formula $\pi=3{,}14$
\end_inset

.
 incorrect:
 
\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
lstinline[language=TeX]|$
\backslash
pi=3,14$|
\end_layout

\end_inset

 yields:
 
\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
raisebox{-1mm}{
\end_layout

\end_inset

 
\begin_inset Graphics
	filename figures/03commadistance/commadistance.png
	width 19mm

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout

}
\end_layout

\end_inset


\end_layout

\begin_layout Standard
[Note:
 Typically in English,
 the decimal point is used instead of a comma,].
\end_layout

